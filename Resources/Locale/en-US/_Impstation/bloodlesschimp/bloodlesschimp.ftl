roles-antag-bloodless-chimp-name = Bloodless Chimp

roles-antag-bloodless-chimp-objective = The need to annihilate your target is the entire reason for your being.

ghost-role-information-bloodless-chimp-name = The Bloodless Chimp

ghost-role-information-bloodless-chimp-description = A strange abberation, it is filled with an intense desire to kill a crewmember.

ghost-role-information-bloodless-chimp-rules =  You are a [color=red][bold] Bloodless Chimp [/bold][/color].
                                                Your instincts tell you that you must kill the target chosen for you. This person will be in your character menu.
                                                The death of your target is your one and only goal. You may kill others if this would assist in your cause.

                                                You don't remember any of your previous life, and you don't remember anything you learned as a ghost.

objective-issuer-instinct = Instinct

reagent-name-AntiChimpSalve = Anti Chimp Salve

reagent-desc-AntiChimpSalve = A strange, experimental toxin. If you manage to actually get it on a bloodless chimp it will inhibit its innate healing factor for around a minute.

station-event-bloodless-chimp-hunt-announcement =   [head=3]Chimp Announcement:[/head]
                                                    Something wicked this way comes.
