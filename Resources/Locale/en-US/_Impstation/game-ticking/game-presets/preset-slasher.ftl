# Dark Step action
slasher-action-dark-step-name = Dark Step
slasher-action-dark-step-desc = Channel briefly, then vanish into the shadows and reappear in a nearby dark location.
slasher-dark-step-start = You begin to melt into the darkness...
slasher-dark-step-success = You step through the dark.
slasher-dark-step-fail = There is nowhere dark enough nearby to step to.

# Dark Heal action
slasher-action-dark-heal-name = Dark Heal
slasher-action-dark-heal-desc = Mend your wounds, but only while you stand in darkness.
slasher-dark-heal-fail = It's too bright for your wounds to knit shut.
slasher-dark-heal-no-damage = You have nothing to mend.

# Weapon Recall action
slasher-action-weapon-recall-name = Recall Weapon
slasher-action-weapon-recall-desc = Mark a held weapon on first use, then recall it to your hand from anywhere on second use.

# Death and maze teleport
slasher-death-mist = Dark mists pour from your wounds as you fall...
slasher-maze-arrival = You wake somewhere dark and unfamiliar. Find your way back.

# Ghost blocking
slasher-ghost-blocked-crit = Your spirit cannot pass while your body still draws breath, the entity has plans for you yet.

# Slasher gear store
slasher-gear-window-title = Slasher's Gear
slasher-gear-window-description = Pick {$maxCount} cosmetic set from the bag.

slasher-gear-set-clown-name = Clown Set
slasher-gear-set-clown-description = Includes: bloody white clown gloves, slasher clown mask, jumpsuit, coat, and clown shoes.

slasher-gear-set-griffy-name = Griffy Set
slasher-gear-set-griffy-description = Includes: griffy head, griffy suit, and griffy PDA.

slasher-gear-set-captain-name = Captain Set
slasher-gear-set-captain-description = Includes: slasher captain cap, Slasher's Captain Carapace, Slasher captain's jumpsuit, bloody captain gloves, and slasher's jump boots.
