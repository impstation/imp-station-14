roles-antag-slasher-name = Slasher
roles-antag-slasher-objective = Survive and terrorize the station.
slasher-role-greeting = You are the Slasher.
guide-entry-slasher = Slasher

slasher-round-end-slasher-major = Slasher Major - The ritual was completed.
slasher-round-end-slasher-major-plural = Slasher Major - The ritual was completed.
slasher-round-end-crew-minor = Crew Minor - The Slasher was unable to complete the ritual.
slasher-round-end-crew-minor-plural = Crew Minor - The Slashers were unable to complete the ritual.
slasher-round-end-crew-major = Crew Major - The Slasher was defeated.
slasher-round-end-crew-major-plural = Crew Major - The Slashers were defeated.
slasher-round-end-list-start = Slasher identities:
slasher-round-end-list-entry = {$name} ({$username}) was a Slasher.

# Slasher hotbar actions
slasher-action-gain-shroud-name = Vanish
slasher-action-gain-shroud-desc = Fade from view. Activating this ability causes you to bleed. Overly hostile intent will cause you to return.
slasher-action-lose-shroud-name = Step Into View
slasher-action-lose-shroud-desc = Voluntarily return to visibility.
slasher-shroud-on = You fade into the background...
slasher-shroud-off = You step back into the foreground.
slasher-shroud-off-others = A figure enters view.
slasher-shroud-broken-by-flash = A bright light brings you into vision!
slasher-shroud-broken-by-flash-others = A figure is forced into view!

# Rend action
slasher-action-rend-name = Rend
slasher-action-rend-desc = Tear through an adjacent wall, window, or door with your supernatural strength.
slasher-rend-start = Strange forces start to rend through the obstacle!
slasher-rend-complete = The obstacle was completely destroyed!
slasher-rend-no-target = There is nothing here to rend.

# Slasher meat hook
slasher-meathook-unhook-denied = You cannot free victims from your own meathook.
slasher-meathook-harvest-success = You harvest a soul fragment.
slasher-meathook-harvest-blocked = This victim's soul cannot be harvested again yet.
slasher-meathook-harvest-empty-hand = You need enough free hands to harvest a soul fragment.
slasher-meathook-harvest-dead = The dead have no soul left to harvest.
slasher-meathook-harvest-invalid-target = You can only harvest from living victims or bodies that died in the last 3 minutes.
slasher-meathook-harvest-no-victim = There is no hooked victim to harvest from.
slasher-meathook-unhook-left-click = Use an empty hand to pull them off the hook.
slasher-meathook-harvested-examine = [color=red]This person looks visibly drained and pale.[/color]
slasher-meathook-hook-invalid-target = You can only hook critical victims or bodies that died in the last 3 minutes.
slasher-soul-fragment-fades = The soul fragment slips from your grasp and dissolves into the aether.

# Meathook placement action
slasher-action-place-meathook-name = Plant Meathook
slasher-action-place-meathook-desc = Sink a meathook into the floor at a target location.
slasher-meathook-place-invalid = You can't plant a hook there.
slasher-meathook-place-depleted = You're out of meathooks.
slasher-meathook-place-too-close-effigy = The ritual resists this placement. Plant the hook at least {$distance} tiles from your effigy.
slasher-place-invalid-too-far = That placement is too far away. Move within {$distance} tiles.
slasher-place-invalid-no-grid = You must place that on station flooring.
slasher-place-invalid-space = You can't place that on space or empty tiles.
slasher-place-invalid-blocked = Something blocks that tile.

# Effigy placement and insertion
slasher-action-place-effigy-name = Plant Effigy
slasher-action-place-effigy-desc = Place your shared blood effigy at a target location.
slasher-effigy-place-invalid = You can't plant the effigy there.
slasher-effigy-place-no-rule = The ritual cannot begin right now.
slasher-effigy-place-already = Your ritual already has an effigy.
slasher-effigy-place-active = An active effigy already exists.
slasher-effigy-insert-need-fragment = You need a soul fragment to feed the effigy.
slasher-effigy-crackle-shift = The Effigy begins to crackle and shift.
slasher-effigy-insert-complete = The effigy is fully fed.
slasher-effigy-restore-begin = You begin channeling the fragment's energy to reconstitute the effigy...
slasher-effigy-restore-complete = The effigy reforms from the shadows. You may place it again.
slasher-effigy-revealed = The effigy becomes visible, and vulnerable!
slasher-effigy-damaged-warning = Your effigy is being attacked!
slasher-effigy-destroyed = Your effigy has been destroyed!
slasher-effigy-destroyed-others = The sense of dread that filled the air suddenly dissipates.
slasher-effigy-hide = The effigy fades back into the shadows.
anomaly-scanner-effigy-hidden = The scanner cannot lock onto this dormant signature.
anomaly-scanner-effigy-hidden-readout = Signature unstable. Re-scan while the target is revealed.
anomaly-scanner-effigy-countdown = Vulnerability window expires in: [color=crimson]{$seconds}s[/color]

